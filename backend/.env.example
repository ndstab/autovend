LOCUS_API_KEY=
LOCUS_API_URL=https://beta-api.paywithlocus.com
LOCUS_WALLET_ID=
ANTHROPIC_API_KEY=
DATABASE_PATH=./data/autovend.db
PORT=3001

# Public base URL of this backend — used when constructing deployed API endpoint URLs.
# In local dev leave unset (defaults to http://localhost:$PORT).
# In production set to your deployed backend, e.g. https://autovend-api.up.railway.app
AUTOVEND_BASE_URL=

# Where to store generated API source + SQLite files (optional, defaults to ./data/apis)
APIS_DIR=

# Required to enable the admin withdraw endpoint. Pick a long random string.
# If unset, the /api/dashboard/withdraw route is disabled entirely.
ADMIN_SECRET=
